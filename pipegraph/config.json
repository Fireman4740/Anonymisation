{
	"_doc": "Un seul champ 'model' suffit. Pour overrider par rôle, ajoutez models.detect / models.audit / models.paraphrase.",

	"llm": {
		"provider": "ollama",
		"model": "gemma4:26b",
		"base_url": "http://localhost:11434/v1",
		"api_key": "",
		"retry_count": 1,
		"fallback_model": null,
		"supports_response_format": false,
		"timeout_seconds": 90
	},

	"openrouter": {
		"base_url": "https://openrouter.ai/api/v1",
		"model": "google/gemma-4-26b-a4b-it",
		"fallback_model": "qwen/qwen3-235b-a22b-2507",
		"timeout_seconds": 60,
		"retry_count": 2,
		"supports_response_format": false,
		"_comment": "Per-role override possible: models.detect, models.audit, models.paraphrase. Autres modèles: openai/gpt-4o-mini, google/gemini-flash-1.5, meta-llama/llama-3.3-70b-instruct:free"
	},

	"features": {
		"llm_detection": true,
		"llm_verification": true,
		"llm_paraphrase": true,
		"llm_audit": true
	},

	"policy_defaults": {
		"paraphrase_intensity": 1,
		"paraphrase_preserve_multiplicity": true,
		"rupta_preserve_entity_counts": true,
		"risk_threshold": 45
	},

	"rupta": {
		"enabled": true,
		"p_threshold": 15,
		"max_iterations": 3,
		"privacy_threshold": null,
		"utility_threshold": 80,
		"temperature": 0.1
	},

	"runtime": {
		"log_level": "INFO",
		"timeout_seconds": 60
	},

	"ner_gpu": {
		"enabled": true,
		"vram_gb": 24,
		"batch_size": 64,
		"max_parallel_models": 3,
		"use_fp16": true,
		"use_torch_compile": false,
		"gliner_preset": "best",
		"prefetch_models": true,
		"optimization_level": "high"
	}
}
