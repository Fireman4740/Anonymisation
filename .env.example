# === SECURITY ===
# Master secret for pseudonymization hashing (REQUIRED in production)
PIPEGRAPH_SEC_PSEUDO_SECRET="change-me-to-a-long-random-string"
# Salt for hashing
PIPEGRAPH_SEC_PSEUDO_SALT="change-me-to-a-unique-salt"
# Environment: development | production
PIPEGRAPH_SEC_ENV="development"

# === GPU / PERFORMANCE ===
# Enable GPU acceleration (requires CUDA)
NER_GPU_ENABLED=false
# Available VRAM in GB
NER_GPU_VRAM_GB=24
# Batch size for inference
NER_GPU_BATCH_SIZE=32
# Use FP16 (requires GPU)
NER_GPU_USE_FP16=true
# Max parallel models to load
NER_GPU_MAX_PARALLEL_MODELS=3

# === DETECTION ===
# Confidence threshold for NER
PIPEGRAPH_DET_DEFAULT_THRESHOLD=0.35
# Path to regex patterns config
PIPEGRAPH_DET_PATTERNS_PATH="config/patterns_config.yaml"

# === GENERAL ===
PIPEGRAPH_DEBUG=false
